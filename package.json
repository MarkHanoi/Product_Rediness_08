{
  "name": "3d-view-app",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "workspaces": [
    "packages/*",
    "tools/*",
    "apps/*",
    "plugins/*"
  ],
  "scripts": {
    "dev": "tsx --env-file-if-exists=.env server.js",
    "start": "node --env-file-if-exists=.env ./dist/index.cjs",
    "migrate": "node --env-file-if-exists=.env scripts/migrate/migrate.mjs",
    "check:isolation": "node scripts/check/check-project-isolation.mjs && node scripts/check/check-storage-isolation.mjs",
    "check:commandmanager": "node scripts/check/ci-check-no-commandmanager.mjs",
    "check:a11y-contrast": "node scripts/check/check-a11y-token-contrast.mjs",
    "scan": "node scripts/scan/scan-logs.js",
    "build": "node scripts/check/check-project-isolation.mjs && tsc --skipLibCheck && node --max-old-space-size=6144 node_modules/vite/bin/vite.js build && node scripts/build/write-prod-shim.mjs",
    "build:app": "npm run build",
    "build:apex": "node scripts/build/prerender-apex.mjs",
    "preview": "node server.js",
    "schemas:test": "npm test --workspace=@pryzm/schemas",
    "schemas:typecheck": "tsc -p packages/schemas/tsconfig.tests.json --noEmit",
    "protocol:typecheck": "tsc -p packages/protocol/tsconfig.json --noEmit",
    "test:pryzm1": "tsx --test tests/*.test.ts",
    "gen:openapi": "node scripts/build/gen-openapi.mjs",
    "gen:docs-site-pricing": "node scripts/build/gen-docs-site-pricing.mjs",
    "lint": "eslint . --max-warnings=999999",
    "wireup:baseline": "scripts/one-offs/wireup-baseline.sh > .local/wireup-floor.json",
    "ga-gate": "node packages/release/src/ga-gate.mjs",
    "pryzm-3-functional-day-1": "tsx scripts/legacy-pryzm3/pryzm-3-functional-day-1.ts",
    "test:ci": "pnpm -r --workspace-concurrency=1 --if-present run test:ci",
    "test:quarantined": "pnpm -r --workspace-concurrency=1 --if-present run test:quarantined",
    "test:server": "vitest run --config vitest.server.config.ts"
  },
