{
  "name": "@pryzm/sync-server",
  "version": "0.1.0",
  "description": "PRYZM 2 — server-side sync skeleton (S22).  Linearises CommandEvents per project (monotonic, gap-free sequence numbers via in-memory mutex or Postgres advisory lock), broadcasts via WebSocket to subscribed clients, and fire-and-forget enqueues bake jobs to apps/bake-worker.  v0 ships LWW semantics; full Yjs CRDT lands in Phase 2D (S43).  Implements code-level ADR-0019.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./protocol": "./src/protocol/messages.ts",
    "./session": "./src/session/SessionManager.ts",
    "./eventLog": "./src/eventLog/createEventLog.ts",
    "./bakeEnqueuer": "./src/bake/createBakeEnqueuer.ts",
    "./cde": "./src/cde/index.ts"
  },
  "files": ["src", "dist"],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@pryzm/bake-worker": "workspace:*",
    "express": "^5.1.0",
    "ulid": "^3.0.1",
    "ws": "^8.18.2",
    "yjs": "^13.6.18"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.18.0",
    "pg": "^8.13.1",
    "tsx": "^4.20.7",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
