{
  "name": "@pryzm/editor",
  "version": "0.1.0",
  "description": "PRYZM 2 — L7 editor application.  S05 ships the bootstrap data half (protocol → command-bus → persistence → stores → scene-committer); S06 D5 adds the render half + start() pump.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./bootstrap": "./src/bootstrap.ts",
    "./bootstrap.data": "./src/bootstrap.data.ts",
    "./bootstrap.everything": "./src/bootstrap.everything.ts",
    "./bootstrap.render": "./src/bootstrap.render.ts",
    "./bootstrap.render.everything": "./src/bootstrap.render.everything.ts",
    "./plugin-registry": "./src/PluginRegistry.ts",
    "./toolbar": "./src/toolbar/index.ts",
    "./projects": "./src/projects/index.ts",
    "./router": "./src/router.ts"
  },
  "files": ["src"],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pryzm/command-bus": "workspace:*",
    "@pryzm/frame-scheduler": "workspace:*",
    "@pryzm/persistence-client": "workspace:*",
    "@pryzm/plugin-beam": "workspace:*",
    "@pryzm/plugin-ceiling": "workspace:*",
    "@pryzm/plugin-column": "workspace:*",
    "@pryzm/plugin-curtain-wall": "workspace:*",
    "@pryzm/plugin-dimensions": "workspace:*",
    "@pryzm/plugin-door": "workspace:*",
    "@pryzm/plugin-furniture": "workspace:*",
    "@pryzm/plugin-grid": "workspace:*",
    "@pryzm/plugin-handrail": "workspace:*",
    "@pryzm/plugin-plumbing": "workspace:*",
    "@pryzm/plugin-roof": "workspace:*",
    "@pryzm/plugin-rooms": "workspace:*",
    "@pryzm/plugin-annotations": "workspace:*",
    "@pryzm/plugin-selection": "workspace:*",
    "@pryzm/plugin-slab": "workspace:*",
    "@pryzm/plugin-stair": "workspace:*",
    "@pryzm/plugin-structural": "workspace:*",
    "@pryzm/plugin-view": "workspace:*",
    "@pryzm/plugin-wall": "workspace:*",
    "@pryzm/plugin-window": "workspace:*",
    "@pryzm/protocol": "workspace:*",
    "@pryzm/renderer": "workspace:*",
    "@pryzm/scene-committer": "workspace:*",
    "@pryzm/stores": "workspace:*",
    "@pryzm/view-state": "workspace:*"
  },
  "devDependencies": {
    "@pryzm/runtime-composer": "workspace:*",
    "@types/three": "^0.183.1",
    "@webgpu/types": "^0.1.69",
    "three": "^0.183.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
