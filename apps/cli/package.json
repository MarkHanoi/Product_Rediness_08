  },
  "dependencies": {
    "@pryzm/file-format": "workspace:*",
    "@pryzm/persistence-client": "workspace:*",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
