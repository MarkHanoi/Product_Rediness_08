{
  "name": "@pryzm/cli",
  "version": "0.1.0",
  "description": "PRYZM 2 — pryzm-cli: pack/unpack .pryzm v1 files from the shell.",
  "private": true,
  "type": "module",
  "bin": {
    "pryzm-cli": "./src/index.ts"
  },
