---
// IP-A3 iteration A.5.d (redesigned 2026-06-02) — /start RAC chatbot.
//
// Next-gen visual redesign per user feedback ("looks from the 90s —
// make it next-gen"). Same 4-step capture flow, completely new shell:
//
//   - dark inverted glass surface (was light frosted glass)
//   - large display typography with variable weight contrast
//   - pill chips with elevation + hover lift (not bordered boxes)
//   - top step-progress dots (not text "Step 1 / 4")
//   - smooth slide-in transitions between steps
//   - asymmetric layout (heading + answer column instead of stacked)
//   - subtle ambient glow around the canvas
//
// Same flow:  role → team size → typology → brief → handoff
//
// Architectural note (the two-surface split):
//   pryzm.so is the MARKETING apex (Cloudflare Pages static). The
//   editor (Sign-in → Project Hub → Main Canvas) lives at
//   app.pryzm.so via the Replit deployment. This /start surface is
//   the BRIDGE — it captures the user's brief on the marketing site
//   then hands off to the editor (today: redirect to /pricing; future:
//   POST to /api/leads + open app.pryzm.so with a session token).
//
// Documented in docs/01-strategy/UI-UX-ARCHITECTURE.md (A.M.0).
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PRYZM — Build your world</title>
    <meta name="description" content="Tell PRYZM about your project. We'll route you to the right workflow." />
    <style>
      @property --b1x { syntax: '<percentage>'; initial-value: 5%;  inherits: false; }
      @property --b1y { syntax: '<percentage>'; initial-value: 55%; inherits: false; }
      @property --b2x { syntax: '<percentage>'; initial-value: 92%; inherits: false; }
      @property --b2y { syntax: '<percentage>'; initial-value: 18%; inherits: false; }
      @property --b3x { syntax: '<percentage>'; initial-value: 72%; inherits: false; }
      @property --b3y { syntax: '<percentage>'; initial-value: 90%; inherits: false; }
      @property --b4x { syntax: '<percentage>'; initial-value: 40%; inherits: false; }
      @property --b4y { syntax: '<percentage>'; initial-value: 5%;  inherits: false; }
      @property --b5x { syntax: '<percentage>'; initial-value: 25%; inherits: false; }
      @property --b5y { syntax: '<percentage>'; initial-value: 30%; inherits: false; }
      @property --b6x { syntax: '<percentage>'; initial-value: 78%; inherits: false; }
      @property --b6y { syntax: '<percentage>'; initial-value: 65%; inherits: false; }

      @keyframes mesh-flow {
        0%   { --b1x:  5%; --b1y: 55%; --b2x: 92%; --b2y: 18%; --b3x: 72%; --b3y: 90%; --b4x: 40%; --b4y:  5%; --b5x: 25%; --b5y: 30%; --b6x: 78%; --b6y: 65%; }
        50%  { --b1x:  8%; --b1y: 18%; --b2x: 90%; --b2y: 82%; --b3x: 48%; --b3y: 55%; --b4x: 20%; --b4y: 35%; --b5x: 80%; --b5y: 40%; --b6x: 35%; --b6y: 75%; }
        100% { --b1x:  5%; --b1y: 55%; --b2x: 92%; --b2y: 18%; --b3x: 72%; --b3y: 90%; --b4x: 40%; --b4y:  5%; --b5x: 25%; --b5y: 30%; --b6x: 78%; --b6y: 65%; }
      }

      :root {
        --ink: #0a0a14;
        --ink-2: #14141f;
        --ink-3: #1c1c2b;
        --line: rgba(255, 255, 255, 0.08);
        --line-2: rgba(255, 255, 255, 0.14);
        --text-1: #ffffff;
        --text-2: rgba(255, 255, 255, 0.72);
        --text-3: rgba(255, 255, 255, 0.46);
        --accent: #8c4dff;
        --accent-2: #b89dfa;
        --accent-glow: rgba(140, 77, 255, 0.45);
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; min-height: 100vh; overflow-x: hidden; }
      body {
        background:
          radial-gradient(ellipse 90% 70% at var(--b1x) var(--b1y), #c8b6ff 0%, transparent 65%),
          radial-gradient(ellipse 70% 60% at var(--b2x) var(--b2y), #b8a2ff 0%, transparent 58%),
          radial-gradient(ellipse 65% 55% at var(--b3x) var(--b3y), #daceff 0%, transparent 55%),
          radial-gradient(ellipse 55% 45% at var(--b4x) var(--b4y), #ece7ff 0%, transparent 50%),
          radial-gradient(ellipse 35% 29% at var(--b5x) var(--b5y), #b89dfa 0%, transparent 48%),
          radial-gradient(ellipse 32% 27% at var(--b6x) var(--b6y), #c49bfb 0%, transparent 45%),
          #f3f0ff;
        animation: mesh-flow 65s ease-in-out infinite;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        font-feature-settings: "cv11", "ss01";
        -webkit-font-smoothing: antialiased;
        color: #0b0b12;
        min-height: 100vh;
      }
      @media (prefers-reduced-motion: reduce) { body { animation: none; } }

      header.site-nav {
        position: absolute;
        top: 0; left: 0; right: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 2rem;
        z-index: 5;
      }
      .brand {
        display: inline-flex; align-items: center; gap: 0.6rem;
        color: #0b0b12; text-decoration: none;
        font-weight: 800; letter-spacing: 0.12em;
        text-transform: uppercase; font-size: 1rem;
      }
      .brand-icon { width: 22px; height: 22px; }
      nav.site-links { display: flex; gap: 1.4rem; align-items: center; }
      nav.site-links a {
        color: rgba(11, 11, 18, 0.7);
        text-decoration: none; font-weight: 500; font-size: 0.92rem;
      }
      nav.site-links a:hover { color: #6600ff; }

      /* ── The canvas — dark inverted glass with ambient glow ── */
      .canvas {
        position: fixed;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: min(640px, calc(100vw - 32px));
        height: min(680px, calc(100vh - 32px));
        min-width: 380px;
        min-height: 520px;
        max-width: calc(100vw - 16px);
        max-height: calc(100vh - 16px);
        background:
          linear-gradient(180deg, rgba(28, 28, 43, 0.92) 0%, rgba(20, 20, 31, 0.94) 100%);
        backdrop-filter: blur(40px) saturate(140%);
        -webkit-backdrop-filter: blur(40px) saturate(140%);
        border: 1px solid var(--line-2);
        border-radius: 22px;
        box-shadow:
          0 40px 100px rgba(60, 10, 160, 0.28),
          0 0 0 1px rgba(255, 255, 255, 0.04) inset,
          0 -20px 80px rgba(140, 77, 255, 0.15) inset;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        animation: canvas-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
        z-index: 10;
        color: var(--text-1);
      }
      @keyframes canvas-in {
        from { opacity: 0; transform: translate(-50%, -46%) scale(0.94); }
        to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
      }

      /* Ambient glow behind the canvas */
      .canvas::before {
        content: '';
        position: absolute;
        inset: -40px;
        background:
          radial-gradient(ellipse 80% 50% at 50% 0%, var(--accent-glow), transparent 70%),
          radial-gradient(ellipse 60% 40% at 50% 100%, rgba(184, 157, 250, 0.3), transparent 70%);
        z-index: -1;
        pointer-events: none;
        filter: blur(20px);
      }

      .canvas-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 24px 14px;
        cursor: grab;
        user-select: none;
        border-bottom: 1px solid var(--line);
      }
      .canvas-header.dragging { cursor: grabbing; }
      .canvas-eyebrow {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--accent-2);
      }
      .canvas-close {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid var(--line);
        color: var(--text-2);
        width: 32px; height: 32px;
        border-radius: 8px;
        font-size: 1.25rem;
        line-height: 1;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
      }
      .canvas-close:hover { background: rgba(255, 255, 255, 0.12); color: var(--text-1); border-color: var(--line-2); }

      /* Step-progress dots */
      .progress-dots {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 0 24px 0;
        margin-top: 16px;
      }
      .dot {
        height: 3px;
        flex: 1;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 999px;
        position: relative;
        overflow: hidden;
        transition: background 0.3s;
      }
      .dot.active::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
        border-radius: 999px;
        animation: dot-fill 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      .dot.done { background: var(--accent); }
      @keyframes dot-fill {
        from { transform: translateX(-100%); }
        to   { transform: translateX(0); }
      }

      .canvas-body {
        flex: 1;
        overflow-y: auto;
        padding: 32px 32px 16px;
        scroll-behavior: smooth;
      }
      .canvas-body::-webkit-scrollbar { width: 6px; }
      .canvas-body::-webkit-scrollbar-thumb { background: var(--line-2); border-radius: 3px; }

      .step {
        animation: step-in 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      @keyframes step-in {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .eyebrow {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-3);
        margin: 0 0 12px;
      }
      .display {
        font-size: clamp(1.65rem, 3.2vw, 2.15rem);
        font-weight: 700;
        line-height: 1.15;
        letter-spacing: -0.02em;
        color: var(--text-1);
        margin: 0 0 6px;
      }
      .display em {
        font-style: normal;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .sub {
        font-size: 0.95rem;
        color: var(--text-2);
        line-height: 1.5;
        margin: 0 0 26px;
        max-width: 38ch;
      }

      /* Pill chips — modern, elevated, hover-lift */
      .pills {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 8px;
      }
      .pill {
        --pill-bg: rgba(255, 255, 255, 0.05);
        --pill-border: rgba(255, 255, 255, 0.10);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 11px 18px;
        background: var(--pill-bg);
        border: 1px solid var(--pill-border);
        border-radius: 999px;
        color: var(--text-1);
        font-weight: 500;
        font-size: 0.93rem;
        cursor: pointer;
        font-family: inherit;
        transition: transform 0.15s cubic-bezier(0.16, 1, 0.3, 1),
                    background 0.18s, border-color 0.18s,
                    box-shadow 0.18s;
        position: relative;
      }
      .pill:hover {
        background: rgba(255, 255, 255, 0.10);
        border-color: rgba(255, 255, 255, 0.22);
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.18);
      }
      .pill.selected {
        background: linear-gradient(135deg, var(--accent), #6f2bdd);
        border-color: transparent;
        box-shadow:
          0 8px 24px rgba(140, 77, 255, 0.4),
          0 0 0 1px rgba(255, 255, 255, 0.18) inset;
      }
      .pill.selected::before {
        content: '';
        width: 6px; height: 6px;
        background: #fff;
        border-radius: 999px;
        box-shadow: 0 0 8px rgba(255, 255, 255, 0.8);
      }

      /* Card-style typology pills (larger, with subtext) */
      .typ-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 10px;
      }
      .typ-card {
        --card-bg: rgba(255, 255, 255, 0.04);
        --card-border: rgba(255, 255, 255, 0.08);
        text-align: left;
        padding: 16px 18px;
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 14px;
        color: var(--text-1);
        cursor: pointer;
        font-family: inherit;
        transition: transform 0.15s cubic-bezier(0.16, 1, 0.3, 1),
                    background 0.18s, border-color 0.18s,
                    box-shadow 0.18s;
      }
      .typ-card:hover {
        background: rgba(255, 255, 255, 0.07);
        border-color: rgba(255, 255, 255, 0.18);
        transform: translateY(-2px);
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.22);
      }
      .typ-card.selected {
        background: linear-gradient(135deg, rgba(140, 77, 255, 0.22), rgba(184, 157, 250, 0.12));
        border-color: var(--accent);
        box-shadow: 0 0 0 1px var(--accent) inset, 0 12px 30px rgba(140, 77, 255, 0.32);
      }
      .typ-card-name { font-weight: 600; font-size: 1rem; margin-bottom: 4px; display: block; }
      .typ-card-gate {
        font-size: 0.74rem;
        color: var(--text-3);
        letter-spacing: 0.02em;
      }
      .typ-card.selected .typ-card-gate { color: var(--accent-2); }

      /* Text input */
      .text-input {
        width: 100%;
        padding: 14px 16px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--line);
        border-radius: 12px;
        font-size: 0.98rem;
        font-family: inherit;
        color: var(--text-1);
        resize: vertical;
        min-height: 100px;
        outline: none;
        transition: border-color 0.18s, background 0.18s, box-shadow 0.18s;
      }
      .text-input::placeholder { color: var(--text-3); }
      .text-input:focus {
        border-color: var(--accent);
        background: rgba(255, 255, 255, 0.06);
        box-shadow: 0 0 0 4px rgba(140, 77, 255, 0.18);
      }

      .captured-strip {
        margin-top: 14px;
        font-size: 0.82rem;
        color: var(--text-3);
        font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
      }
      .captured-strip strong {
        color: var(--accent-2);
        font-weight: 500;
      }

      /* Summary card (done state) */
      .summary {
        display: grid;
        gap: 14px;
        padding: 22px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--line);
        border-radius: 16px;
        margin-bottom: 18px;
      }
      .summary-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 12px;
      }
      .summary-row .k {
        font-size: 0.74rem;
        color: var(--text-3);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        font-weight: 500;
      }
      .summary-row .v {
        font-size: 1rem;
        color: var(--text-1);
        font-weight: 600;
        text-align: right;
      }
      .summary-brief {
        grid-column: 1 / -1;
        padding-top: 14px;
        border-top: 1px solid var(--line);
      }
      .summary-brief .k {
        display: block; margin-bottom: 6px;
        font-size: 0.74rem;
        color: var(--text-3);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        font-weight: 500;
      }
      .summary-brief .v {
        font-size: 0.95rem;
        font-weight: 400;
        color: var(--text-2);
        line-height: 1.5;
      }
      .next-step-hint {
        padding: 16px 18px;
        background: linear-gradient(135deg, rgba(140, 77, 255, 0.10), rgba(184, 157, 250, 0.04));
        border: 1px solid rgba(140, 77, 255, 0.22);
        border-radius: 12px;
        color: var(--text-2);
        font-size: 0.9rem;
        line-height: 1.55;
      }
      .next-step-hint strong { color: var(--accent-2); font-weight: 600; }

      /* Footer */
      .canvas-footer {
        padding: 18px 24px 22px;
        border-top: 1px solid var(--line);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }
      .back-btn {
        background: transparent;
        border: none;
        color: var(--text-3);
        font-size: 0.88rem;
        cursor: pointer;
        padding: 8px 4px;
        font-family: inherit;
        transition: color 0.15s;
      }
      .back-btn:hover { color: var(--text-1); }
      .back-btn:disabled { opacity: 0.3; cursor: not-allowed; }
      .next-btn {
        background: linear-gradient(135deg, var(--accent), #6f2bdd);
        color: #fff;
        border: none;
        padding: 12px 24px;
        border-radius: 999px;
        font-weight: 600;
        font-size: 0.92rem;
        cursor: pointer;
        font-family: inherit;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: transform 0.12s, filter 0.12s, box-shadow 0.18s;
        box-shadow: 0 8px 20px rgba(140, 77, 255, 0.32);
      }
      .next-btn:hover {
        filter: brightness(1.1);
        transform: translateY(-1px);
        box-shadow: 0 12px 28px rgba(140, 77, 255, 0.42);
      }
      .next-btn:disabled {
        background: rgba(255, 255, 255, 0.06);
        color: var(--text-3);
        cursor: not-allowed;
        box-shadow: none;
        transform: none;
        filter: none;
      }
      .next-btn .arrow {
        transition: transform 0.18s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .next-btn:hover:not(:disabled) .arrow { transform: translateX(3px); }

      /* Resize handle */
      .resize-handle {
        position: absolute;
        right: 4px; bottom: 4px;
        width: 14px; height: 14px;
        cursor: nwse-resize;
        background:
          linear-gradient(135deg, transparent 50%, rgba(255, 255, 255, 0.18) 50%, rgba(255, 255, 255, 0.18) 60%, transparent 60%, transparent 72%, rgba(255, 255, 255, 0.18) 72%, rgba(255, 255, 255, 0.18) 82%, transparent 82%);
        border-radius: 0 0 16px 0;
      }

      @media (max-width: 640px) {
        .canvas { width: calc(100vw - 16px); height: calc(100vh - 16px); border-radius: 18px; }
        .canvas-body { padding: 24px 20px 12px; }
        .display { font-size: 1.4rem; }
        .canvas-header { padding: 14px 18px 12px; }
        .canvas-footer { padding: 14px 18px 18px; }
      }
    </style>
  </head>
  <body>
    <header class="site-nav">
      <a class="brand" href="/">
        <svg class="brand-icon" viewBox="0 0 36 36" fill="none" aria-hidden="true">
          <path d="M18.2 2.6 3.6 27.9 26.8 33.2 32.4 23.6 18.2 2.6Z" stroke="#0b0b12" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round"/>
          <path d="M18.2 2.6 3.6 27.9" stroke="#6600FF" stroke-width="1.6" stroke-linecap="round"/>
          <path d="M18.2 2.6 26.8 33.2" stroke="#0b0b12" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        PRYZM
      </a>
      <nav class="site-links" aria-label="Primary">
        <a href="/manifesto">Manifesto</a>
        <a href="/pricing">Pricing</a>
        <a href="/trust">Trust</a>
      </nav>
    </header>

    <section class="canvas" id="rac-canvas" role="dialog" aria-label="PRYZM onboarding interview">
      <header class="canvas-header" id="rac-header">
        <span class="canvas-eyebrow">Build your world · Interview</span>
        <button class="canvas-close" id="rac-close" aria-label="Close">×</button>
      </header>
      <div class="progress-dots" id="rac-dots">
        <div class="dot" data-step="0"></div>
        <div class="dot" data-step="1"></div>
        <div class="dot" data-step="2"></div>
        <div class="dot" data-step="3"></div>
      </div>
      <div class="canvas-body" id="rac-body"></div>
      <footer class="canvas-footer">
        <button class="back-btn" id="rac-back" disabled>← Back</button>
        <button class="next-btn" id="rac-next" disabled>
          <span class="next-label">Continue</span>
          <span class="arrow">→</span>
        </button>
      </footer>
      <div class="resize-handle" id="rac-resize" aria-hidden="true"></div>
    </section>

    <script>
      const STEPS = ['role', 'companySize', 'typology', 'brief', 'done'];
      const ROLE_OPTIONS = ['Architect', 'Engineer', 'Developer', 'Contractor', 'Owner', 'Student'];
      const COMPANY_SIZE_OPTIONS = ['Solo', '2–10', '11–50', '51–200', '200+'];
      const TYPOLOGY_OPTIONS = [
        { id: 'apartment',    label: 'Apartment',    gate: 'Alpha · ready' },
        { id: 'house',        label: 'House',        gate: 'Next sprint' },
        { id: 'small-office', label: 'Small office', gate: 'Next sprint' },
      ];

      const state = { stepIdx: 0, role: null, companySize: null, typology: null, brief: '' };

      const $body  = document.getElementById('rac-body');
      const $back  = document.getElementById('rac-back');
      const $next  = document.getElementById('rac-next');
      const $close = document.getElementById('rac-close');
      const $nextLabel = $next.querySelector('.next-label');

      function step() { return STEPS[state.stepIdx]; }
      function canAdvance() {
        switch (step()) {
          case 'role':        return !!state.role;
          case 'companySize': return !!state.companySize;
          case 'typology':    return !!state.typology;
          case 'brief':       return true;
          case 'done':        return false;
        }
      }

      function renderDots() {
        document.querySelectorAll('.dot').forEach((el, i) => {
          el.classList.toggle('active', i === state.stepIdx && state.stepIdx < 4);
          el.classList.toggle('done',   i <  state.stepIdx);
        });
      }

      function renderRole() {
        return `
          <div class="step">
            <p class="eyebrow">01 · Profile</p>
            <h2 class="display">Who's <em>building</em>?</h2>
            <p class="sub">Pick the role that fits best. We'll tailor the workflow.</p>
            <div class="pills" id="role-pills"></div>
          </div>`;
      }
      function renderCompanySize() {
        return `
          <div class="step">
            <p class="eyebrow">02 · Team</p>
            <h2 class="display">How <em>big</em> is the team?</h2>
            <p class="sub">Solo · small studio · growing firm. The tier we suggest depends on this.</p>
            <div class="pills" id="size-pills"></div>
          </div>`;
      }
      function renderTypology() {
        return `
          <div class="step">
            <p class="eyebrow">03 · Project</p>
            <h2 class="display">What are you <em>designing</em>?</h2>
            <p class="sub">More typologies (retail · school · gym · clinic) ship through Phase B + C.</p>
            <div class="typ-grid" id="typ-grid"></div>
          </div>`;
      }
      function renderBrief() {
        const cap = `<strong>${state.role}</strong> · <strong>${state.companySize}</strong> · <strong>${state.typology}</strong>`;
        return `
          <div class="step">
            <p class="eyebrow">04 · Brief <span style="color:var(--text-3);font-weight:400;text-transform:none;letter-spacing:0">— optional</span></p>
            <h2 class="display">Anything we should <em>know</em>?</h2>
            <p class="sub">Size, bedrooms, style, vibe — anything top of mind. Skip it and we'll ask in the editor.</p>
            <textarea class="text-input" id="brief-input" placeholder="e.g. 2-bed apartment · 70 m² · modern · south-facing balcony"></textarea>
            <div class="captured-strip">Captured · ${cap}</div>
          </div>`;
      }
      function renderDone() {
        return `
          <div class="step">
            <p class="eyebrow">Captured</p>
            <h2 class="display">Good. Next stop — your <em>site</em>.</h2>
            <p class="sub">We'll pin the project location and trace the parcel boundary, then open the canvas with the site already loaded.</p>
            <div class="summary">
              <div class="summary-row"><span class="k">Role</span><span class="v">${state.role}</span></div>
              <div class="summary-row"><span class="k">Team</span><span class="v">${state.companySize}</span></div>
              <div class="summary-row"><span class="k">Project</span><span class="v">${state.typology}</span></div>
              ${state.brief ? `<div class="summary-brief"><span class="k">Brief</span><span class="v">${state.brief.replace(/</g, '&lt;')}</span></div>` : ''}
            </div>
            <div class="next-step-hint">
              <strong>Next →</strong> the editor lives at <strong>app.pryzm.so</strong> (alpha · invitation only). Hit <em>Continue</em> to join the waitlist with your brief attached.
            </div>
          </div>`;
      }

      function attachPills($host, options, selectedKey, onPick) {
        options.forEach(opt => {
          const isObj = typeof opt === 'object';
          const label = isObj ? opt.label : opt;
          const value = isObj ? opt.id    : opt;
          const b = document.createElement('button');
          b.type = 'button';
          b.className = 'pill' + (state[selectedKey] === value ? ' selected' : '');
          b.textContent = label;
          b.addEventListener('click', () => { onPick(value); render(); });
          $host.appendChild(b);
        });
      }
      function attachTypCards($host) {
        TYPOLOGY_OPTIONS.forEach(t => {
          const b = document.createElement('button');
          b.type = 'button';
          b.className = 'typ-card' + (state.typology === t.id ? ' selected' : '');
          b.innerHTML = `<span class="typ-card-name">${t.label}</span><span class="typ-card-gate">${t.gate}</span>`;
          b.addEventListener('click', () => { state.typology = t.id; render(); });
          $host.appendChild(b);
        });
      }

      function render() {
        const s = step();
        if (s === 'role')             $body.innerHTML = renderRole();
        else if (s === 'companySize') $body.innerHTML = renderCompanySize();
        else if (s === 'typology')    $body.innerHTML = renderTypology();
        else if (s === 'brief')       $body.innerHTML = renderBrief();
        else if (s === 'done')        $body.innerHTML = renderDone();

        if (s === 'role')        attachPills(document.getElementById('role-pills'), ROLE_OPTIONS, 'role',        v => state.role = v);
        if (s === 'companySize') attachPills(document.getElementById('size-pills'), COMPANY_SIZE_OPTIONS, 'companySize', v => state.companySize = v);
        if (s === 'typology')    attachTypCards(document.getElementById('typ-grid'));
        if (s === 'brief') {
          const $ta = document.getElementById('brief-input');
          if ($ta) {
            $ta.value = state.brief;
            $ta.addEventListener('input', e => { state.brief = e.target.value; });
            setTimeout(() => $ta.focus(), 50);
          }
        }

        renderDots();
        $back.disabled = state.stepIdx === 0 || s === 'done';
        $next.disabled = !canAdvance();
        $nextLabel.textContent =
          s === 'brief' ? 'Finish' :
          s === 'done'  ? 'Continue in editor' :
                          'Continue';
      }

      $next.addEventListener('click', () => {
        if (step() === 'done') {
          console.log('[rac-canvas] captured', state);
          window.location.href = '/manifesto';
          return;
        }
        if (!canAdvance()) return;
        state.stepIdx = Math.min(state.stepIdx + 1, STEPS.length - 1);
        render();
      });
      $back.addEventListener('click', () => {
        if (state.stepIdx === 0) return;
        state.stepIdx -= 1;
        render();
      });
      $close.addEventListener('click', () => { window.location.href = '/'; });

      render();

      // ── Drag + resize ────────────────────────────────────────────
      const $canvas = document.getElementById('rac-canvas');
      const $header = document.getElementById('rac-header');
      const $resize = document.getElementById('rac-resize');

      let drag = null;
      $header.addEventListener('mousedown', (e) => {
        if (e.target.closest('button')) return;
        const r = $canvas.getBoundingClientRect();
        drag = { dx: e.clientX - r.left, dy: e.clientY - r.top };
        $header.classList.add('dragging');
        $canvas.style.transform = 'none';
        $canvas.style.left = r.left + 'px';
        $canvas.style.top  = r.top  + 'px';
        e.preventDefault();
      });
      window.addEventListener('mousemove', (e) => {
        if (!drag) return;
        const x = Math.max(0, Math.min(window.innerWidth  - 100, e.clientX - drag.dx));
        const y = Math.max(0, Math.min(window.innerHeight -  60, e.clientY - drag.dy));
        $canvas.style.left = x + 'px';
        $canvas.style.top  = y + 'px';
      });
      window.addEventListener('mouseup', () => {
        if (drag) { drag = null; $header.classList.remove('dragging'); }
      });

      let resize = null;
      $resize.addEventListener('mousedown', (e) => {
        const r = $canvas.getBoundingClientRect();
        resize = { startX: e.clientX, startY: e.clientY, w: r.width, h: r.height };
        e.preventDefault();
      });
      window.addEventListener('mousemove', (e) => {
        if (!resize) return;
        const w = Math.max(380, Math.min(window.innerWidth  - 20, resize.w + (e.clientX - resize.startX)));
        const h = Math.max(520, Math.min(window.innerHeight - 20, resize.h + (e.clientY - resize.startY)));
        $canvas.style.width  = w + 'px';
        $canvas.style.height = h + 'px';
      });
      window.addEventListener('mouseup', () => { if (resize) resize = null; });
    </script>
  </body>
</html>
