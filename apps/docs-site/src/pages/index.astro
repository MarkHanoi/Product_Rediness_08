---
// IP-A5 iteration 5.7 — pryzm.so root landing page (purple-mesh hero).
//
// Pixel-faithful static replica of the editor's L7 LandingPage
// (apps/editor/src/ui/platform/LandingPage.ts + the LANDING_PAGE_STYLES
// constant in apps/editor/src/ui/styles/panels/marketingPages.ts).
//
// Why a static replica rather than serving the editor itself:
//   - pryzm.so is served by Cloudflare Pages (static-only). The editor
//     is an Express + Vite SPA with auth + Postgres + Socket.io — that
//     belongs on app.pryzm.so via the Replit deployment, not on the
//     marketing apex.
//   - The marketing apex needs to feel like the product. So we mirror
//     the editor's hero (PRYZM wordmark + tagline + Start-here pill)
//     using the SAME CSS recipe — 6-blob mesh gradient, white wordmark,
//     drop-shadow, fade-in entrance, glass-pill CTA with float anim.
//
// When the editor LandingPage.ts changes its hero copy or styling, this
// file should be updated in the same PR (the canonical source is
// `apps/editor/src/ui/platform/LandingPage.ts` per its file header).
//
// Astro renders this at build time; zero client-side JS required.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PRYZM — Build the future, intelligently.</title>
    <meta
      name="description"
      content="The browser-native BIM platform. Real-time collaboration, AI-assisted design, contract-grade interoperability. Built for the teams that have to ship a building."
    />
    <meta property="og:title" content="PRYZM — Build the future, intelligently." />
    <meta
      property="og:description"
      content="The browser-native BIM platform. Real-time collaboration, AI-assisted design, contract-grade interoperability."
    />
    <meta property="og:type" content="website" />
    <style>
      @property --b1x { syntax: '<percentage>'; initial-value: 5%;  inherits: false; }
      @property --b1y { syntax: '<percentage>'; initial-value: 55%; inherits: false; }
      @property --b2x { syntax: '<percentage>'; initial-value: 92%; inherits: false; }
      @property --b2y { syntax: '<percentage>'; initial-value: 18%; inherits: false; }
      @property --b3x { syntax: '<percentage>'; initial-value: 72%; inherits: false; }
      @property --b3y { syntax: '<percentage>'; initial-value: 90%; inherits: false; }
      @property --b4x { syntax: '<percentage>'; initial-value: 40%; inherits: false; }
      @property --b4y { syntax: '<percentage>'; initial-value: 5%;  inherits: false; }
      @property --b5x { syntax: '<percentage>'; initial-value: 25%; inherits: false; }
      @property --b5y { syntax: '<percentage>'; initial-value: 30%; inherits: false; }
      @property --b6x { syntax: '<percentage>'; initial-value: 78%; inherits: false; }
      @property --b6y { syntax: '<percentage>'; initial-value: 65%; inherits: false; }

      @keyframes mesh-flow {
        0%   { --b1x:  5%; --b1y: 55%; --b2x: 92%; --b2y: 18%; --b3x: 72%; --b3y: 90%; --b4x: 40%; --b4y:  5%; --b5x: 25%; --b5y: 30%; --b6x: 78%; --b6y: 65%; }
        12%  { --b1x: 45%; --b1y: 22%; --b2x: 60%; --b2y: 72%; --b3x: 88%; --b3y: 35%; --b4x: 12%; --b4y: 58%; --b5x: 70%; --b5y: 15%; --b6x: 18%; --b6y: 82%; }
        25%  { --b1x: 12%; --b1y: 82%; --b2x: 85%; --b2y:  8%; --b3x: 30%; --b3y: 92%; --b4x: 78%; --b4y: 20%; --b5x: 55%; --b5y: 68%; --b6x: 42%; --b6y: 12%; }
        37%  { --b1x: 68%; --b1y: 45%; --b2x: 22%; --b2y: 60%; --b3x: 82%; --b3y: 18%; --b4x: 50%; --b4y: 88%; --b5x: 10%; --b5y: 50%; --b6x: 88%; --b6y: 30%; }
        50%  { --b1x:  8%; --b1y: 18%; --b2x: 90%; --b2y: 82%; --b3x: 48%; --b3y: 55%; --b4x: 20%; --b4y: 35%; --b5x: 80%; --b5y: 40%; --b6x: 35%; --b6y: 75%; }
        62%  { --b1x: 72%; --b1y: 78%; --b2x: 35%; --b2y: 12%; --b3x: 15%; --b3y: 70%; --b4x: 88%; --b4y: 42%; --b5x: 45%; --b5y: 88%; --b6x: 60%; --b6y: 22%; }
        75%  { --b1x: 28%; --b1y: 38%; --b2x: 78%; --b2y: 55%; --b3x: 62%; --b3y: 28%; --b4x: 35%; --b4y: 75%; --b5x: 92%; --b5y: 60%; --b6x: 12%; --b6y: 42%; }
        87%  { --b1x: 55%; --b1y: 88%; --b2x: 15%; --b2y: 35%; --b3x: 92%; --b3y: 72%; --b4x: 62%; --b4y: 12%; --b5x: 30%; --b5y: 20%; --b6x: 72%; --b6y: 85%; }
        100% { --b1x:  5%; --b1y: 55%; --b2x: 92%; --b2y: 18%; --b3x: 72%; --b3y: 90%; --b4x: 40%; --b4y:  5%; --b5x: 25%; --b5y: 30%; --b6x: 78%; --b6y: 65%; }
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; min-height: 100vh; overflow-x: hidden; }
      body {
        background:
          radial-gradient(ellipse 90% 70% at var(--b1x) var(--b1y), #c8b6ff 0%, transparent 65%),
          radial-gradient(ellipse 70% 60% at var(--b2x) var(--b2y), #b8a2ff 0%, transparent 58%),
          radial-gradient(ellipse 65% 55% at var(--b3x) var(--b3y), #daceff 0%, transparent 55%),
          radial-gradient(ellipse 55% 45% at var(--b4x) var(--b4y), #ece7ff 0%, transparent 50%),
          radial-gradient(ellipse 35% 29% at var(--b5x) var(--b5y), #b89dfa 0%, transparent 48%),
          radial-gradient(ellipse 32% 27% at var(--b6x) var(--b6y), #c49bfb 0%, transparent 45%),
          #f3f0ff;
        animation: mesh-flow 65s ease-in-out infinite;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        color: #0b0b12;
        min-height: 100vh;
      }

      header.site-nav {
        position: absolute;
        top: 0; left: 0; right: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 2rem;
        z-index: 5;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        color: #0b0b12;
        text-decoration: none;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-size: 1rem;
      }
      .brand-icon { width: 22px; height: 22px; }
      nav.site-links { display: flex; gap: 1.4rem; align-items: center; }
      nav.site-links a {
        color: rgba(11, 11, 18, 0.7);
        text-decoration: none;
        font-weight: 500;
        font-size: 0.92rem;
        transition: color 0.15s;
      }
      nav.site-links a:hover, nav.site-links a:focus-visible { color: #6600ff; }

      main.hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 72px 24px 96px;
        text-align: center;
        position: relative;
      }
      .hero-glyph { opacity: 0.18; margin-bottom: 8px; }
      .hero-glyph svg { width: clamp(80px, 12vw, 130px); height: auto; display: block; }
      h1.wordmark {
        font-size: clamp(72px, 9.8vw, 146px);
        font-weight: 800;
        line-height: 1;
        color: #ffffff;
        text-shadow: 0 2px 24px rgba(90, 30, 200, 0.22), 0 1px 4px rgba(60, 20, 150, 0.14);
        margin: 0 0 16px;
        letter-spacing: -0.03em;
        text-transform: uppercase;
        animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
      }
      p.tagline {
        font-size: clamp(13px, 1.3vw, 17px);
        color: rgba(255, 255, 255, 0.88);
        line-height: 1.5;
        margin: 0 0 40px;
        max-width: 480px;
        font-weight: 400;
        letter-spacing: 0.01em;
        animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.35s both;
      }
      @keyframes fade-up {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes float-bob {
        0%, 100% { transform: translateY(0); }
        50%      { transform: translateY(-9px); }
      }
      a.start {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(0, 0, 0, 0.28);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.22);
        border-radius: 999px;
        font-size: 9px;
        font-weight: 300;
        font-style: italic;
        padding: 8px 17px;
        cursor: pointer;
        letter-spacing: 0.06em;
        white-space: nowrap;
        text-decoration: none;
        transition: background 0.18s, box-shadow 0.18s, filter 0.18s;
        animation:
          fade-up 0.75s cubic-bezier(0.16, 1, 0.3, 1) 0.75s both,
          float-bob 3.4s ease-in-out 1.6s infinite;
      }
      a.start:hover, a.start:focus-visible {
        background: rgba(0, 0, 0, 0.44);
        filter: brightness(1.18);
        box-shadow: 0 8px 28px rgba(60, 10, 160, 0.26);
        animation-play-state: paused;
      }
      a.start:active { filter: brightness(0.92); }
      a.start svg { flex-shrink: 0; }
      @media (prefers-reduced-motion: reduce) {
        body { animation: none; }
        h1.wordmark, p.tagline, a.start { animation: none; }
      }

      footer.bottom-bar {
        position: fixed;
        bottom: 0; left: 0; right: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 28px;
        height: 56px;
        background: rgba(255, 255, 255, 0.20);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border-top: 1px solid rgba(196, 181, 253, 0.18);
        font-size: 0.85rem;
        color: rgba(11, 11, 18, 0.65);
        z-index: 5;
      }
      footer.bottom-bar a {
        color: rgba(11, 11, 18, 0.7);
        text-decoration: none;
        margin-left: 1.25rem;
      }
      footer.bottom-bar a:hover, footer.bottom-bar a:focus-visible { color: #6600ff; }

      @media (max-width: 760px) {
        header.site-nav { padding: 1rem; flex-wrap: wrap; gap: 0.75rem; }
        nav.site-links { gap: 1rem; }
        nav.site-links a { font-size: 0.85rem; }
        h1.wordmark { font-size: 22vw; }
        footer.bottom-bar { padding: 0 16px; font-size: 0.78rem; }
        footer.bottom-bar a { margin-left: 0.85rem; }
      }
    </style>
  </head>
  <body>
    <header class="site-nav">
      <a class="brand" href="/">
        <svg class="brand-icon" viewBox="0 0 36 36" fill="none" aria-hidden="true">
          <path d="M18.2 2.6 3.6 27.9 26.8 33.2 32.4 23.6 18.2 2.6Z" stroke="#0b0b12" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round"/>
          <path d="M18.2 2.6 3.6 27.9" stroke="#6600FF" stroke-width="1.6" stroke-linecap="round"/>
          <path d="M18.2 2.6 26.8 33.2" stroke="#0b0b12" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        PRYZM
      </a>
      <nav class="site-links" aria-label="Primary">
        <a href="/manifesto">Manifesto</a>
        <a href="/pricing">Pricing</a>
        <a href="/trust">Trust</a>
        <a href="/getting-started">Docs</a>
      </nav>
    </header>

    <main class="hero">
      <div class="hero-glyph" aria-hidden="true">
        <svg viewBox="0 0 36 36" fill="none">
          <path d="M18.2 2.6 3.6 27.9 26.8 33.2 32.4 23.6 18.2 2.6Z" stroke="#ffffff" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round"/>
          <path d="M18.2 2.6 3.6 27.9" stroke="#ffffff" stroke-width="1.6" stroke-linecap="round"/>
          <path d="M18.2 2.6 26.8 33.2" stroke="#ffffff" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <h1 class="wordmark">PRYZM</h1>

      <p class="tagline">Build the future, intelligently.</p>

      <a class="start" href="/pricing">
        <svg width="14" height="18" viewBox="0 0 18 22" fill="none" aria-hidden="true">
          <path d="M0 0L0 17.5L4.5 13L7.5 20L9.5 19.2L6.5 12H12L0 0Z" fill="currentColor"/>
        </svg>
        Start here
      </a>
    </main>

    <footer class="bottom-bar">
      <div>© PRYZM — Alpha</div>
      <div>
        <a href="/manifesto">Manifesto</a>
        <a href="/pricing">Pricing</a>
        <a href="/trust">Trust</a>
        <a href="/getting-started">Docs</a>
      </div>
    </footer>
  </body>
</html>
