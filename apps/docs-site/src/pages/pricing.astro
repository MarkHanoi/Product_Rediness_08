---
// A.18.b (Phase A · Sprint 2) — Pricing page generated from the
// entitlement registry per [C39 §1.13].
//
// "The pricing page MUST be generated from the entitlement registry —
//  no hand-written tier feature lists."
//
// Authority: docs/02-decisions/contracts/C39-PRICING-AND-PLAN-TIERS.md
// Implementation:
//   @pryzm/entitlements (L2-pure) → scripts/build/gen-docs-site-pricing.mjs
//                                  → apps/docs-site/src/data/pricing.json
//                                  → this page (L5; imports the JSON)
//
// Why JSON-snapshot instead of runtime import:
//   Importing @pryzm/entitlements here transitively pulls @pryzm/schemas +
//   zod@4, which collides with Starlight 0.30 + Astro 5's internal zod@3
//   schema invocation during static-route generation. Per ADR-052 §1.4
//   (the marketing-surface JSON-snapshot pattern), marketing pages consume
//   runtime values as build-time JSON artefacts, NOT as workspace imports.
//
// Regenerate with: `pnpm run gen:docs-site-pricing` (this is the contract
// per C39 §1.13; a queued CI gate `check-docs-site-pricing-fresh.mjs`
// fails any PR where the snapshot drifts from the live registry).
//
// Astro renders this at build time — there is no client-side JS shipped
// for the table itself.

import data from '../data/pricing.json';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PRYZM Pricing</title>
    <meta
      name="description"
      content="Per-tier feature comparison generated from the canonical PRYZM entitlement registry."
    />
    <style>
      :root {
        --pryzm-purple: #6600ff;
        --pryzm-ink: #0a0a0f;
        --pryzm-muted: #8a8a96;
        --pryzm-border: #2a2a36;
        --pryzm-paper: #14141c;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        padding: 0;
        background: var(--pryzm-ink);
        color: #f5f5fa;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        line-height: 1.5;
      }
      main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 1.5rem 6rem;
      }
      h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0 0 0.5rem;
        letter-spacing: -0.02em;
      }
      .lede {
        color: var(--pryzm-muted);
        margin: 0 0 3rem;
        font-size: 1.1rem;
      }
      .tiers {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 1rem;
        margin-bottom: 3rem;
      }
      .tier {
        border: 1px solid var(--pryzm-border);
        border-radius: 0.75rem;
        padding: 1.25rem;
        background: var(--pryzm-paper);
      }
      .tier h2 {
        margin: 0 0 0.25rem;
        font-size: 1.15rem;
      }
      .tier .tier-key {
        font-size: 0.8rem;
        color: var(--pryzm-muted);
        font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
      }
      section.category {
        margin-bottom: 2.5rem;
      }
      section.category h3 {
        font-size: 1.3rem;
        margin: 0 0 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--pryzm-purple);
        display: inline-block;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95rem;
      }
      thead th {
        text-align: left;
        padding: 0.75rem 0.75rem;
        border-bottom: 1px solid var(--pryzm-border);
        font-weight: 600;
        color: var(--pryzm-muted);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      thead th.tier-col {
        text-align: center;
        width: 100px;
      }
      tbody td {
        padding: 0.85rem 0.75rem;
        border-bottom: 1px solid var(--pryzm-border);
        vertical-align: top;
      }
      tbody td.tier-cell {
        text-align: center;
        font-size: 1.1rem;
      }
      tbody tr:last-child td {
        border-bottom: none;
      }
      .feature-name {
        font-weight: 600;
        display: block;
        margin-bottom: 0.15rem;
      }
      .feature-desc {
        font-size: 0.85rem;
        color: var(--pryzm-muted);
      }
      .deprecated-badge {
        display: inline-block;
        margin-left: 0.5rem;
        padding: 0.1rem 0.4rem;
        background: rgba(255, 165, 0, 0.15);
        color: #ffa500;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-radius: 0.25rem;
      }
      .yes {
        color: var(--pryzm-purple);
      }
      .no {
        color: #3a3a4a;
      }
      footer.meta {
        margin-top: 4rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--pryzm-border);
        font-size: 0.85rem;
        color: var(--pryzm-muted);
        font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
      }
      footer.meta code {
        background: var(--pryzm-paper);
        padding: 0.1rem 0.4rem;
        border-radius: 0.25rem;
        color: #f5f5fa;
      }
      @media (max-width: 800px) {
        .tiers {
          grid-template-columns: repeat(2, 1fr);
        }
        thead th.tier-col,
        tbody td.tier-cell {
          width: auto;
        }
        h1 {
          font-size: 2rem;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <h1>PRYZM Pricing</h1>
      <p class="lede">
        Five consumer tiers. Every feature gate listed below maps to a
        single canonical key in the PRYZM entitlement registry —
        generated, not hand-written, per
        <a
          href="https://github.com/pryzm-com/pryzm/blob/main/docs/02-decisions/contracts/C39-PRICING-AND-PLAN-TIERS.md"
          style="color: var(--pryzm-purple)">C39 §1.13</a
        >.
      </p>

      <div class="tiers">
        {
          data.tiers.map((tier) => (
            <div class="tier">
              <h2>{data.tierDisplayNames[tier]}</h2>
              <div class="tier-key">{tier}</div>
            </div>
          ))
        }
      </div>

      {
        data.sections.map((section) => (
          <section class="category">
            <h3>{section.displayName}</h3>
            <table>
              <thead>
                <tr>
                  <th>Feature</th>
                  {data.tiers.map((tier) => (
                    <th class="tier-col">{data.tierDisplayNames[tier]}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {section.rows.map((row) => (
                  <tr>
                    <td>
                      <span class="feature-name">
                        {row.displayName}
                        {row.deprecated && (
                          <span class="deprecated-badge">Deprecated</span>
                        )}
                      </span>
                      <span class="feature-desc">{row.description}</span>
                    </td>
                    {data.tiers.map((tier) => (
                      <td class="tier-cell">
                        {row.availability[tier] ? (
                          <span class="yes" aria-label="included">✓</span>
                        ) : (
                          <span class="no" aria-label="not included">—</span>
                        )}
                      </td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </section>
        ))
      }

      <footer class="meta">
        Generated from <code>@pryzm/entitlements</code> ·
        {data.totalEntitlements} feature gates across {data.sections.length}
        categories · Single source of truth per
        <code>C39 §1.13</code>.
      </footer>
    </main>
  </body>
</html>
