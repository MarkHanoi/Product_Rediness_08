# PRYZM — environment configuration template
# Copy this file to `.env` for local dev. NEVER commit a real `.env`.
# All "required" vars MUST be set in production. The server now hard-fails
# at boot when any required var is missing in production (§B5/§H16 audit fix).

# ─── HARD REQUIRED (boot fails without these in production) ────────────────

# Signing secret for JWT session tokens. Must be a long random string and MUST
# be identical across every server instance, or auth silently breaks under
# horizontal scaling (§H16). Generate: `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
SESSION_SECRET=

# Primary Postgres connection. Either DATABASE_URL or SUPABASE_DB_URL must be
# set in production — otherwise the in-memory fallback silently runs and data
# evaporates on restart (§B14).
DATABASE_URL=
# Optional: Supabase direct DB URL (pooler) — preferred when running on Supabase.
SUPABASE_DB_URL=

# Owner email — the account that auto-gets the `owner` plan via
# maybeAutoGrantOwner(). Required so the platform has an admin from day one.
PRYZM_OWNER_EMAIL=

# CORS allowlist. In production this MUST be set to the actual deployed origin
# (comma-separated for multiple). Server fails closed if unset in production
# instead of falling back to `*` (§H1 audit fix).
ALLOWED_ORIGIN=

# Public base URL used to construct OAuth redirect URIs (§H4 audit fix).
# Example: https://app.pryzm.io
PUBLIC_BASE_URL=

# AI upstream. EITHER set CF_WORKER_URL (preferred — Cloudflare Worker holds the
# real Anthropic key as a CF secret) OR ANTHROPIC_API_KEY (direct).
CF_WORKER_URL=
ANTHROPIC_API_KEY=

# ─── REQUIRED FOR FULL FUNCTIONALITY ───────────────────────────────────────

# Initial password for PRYZM_OWNER_EMAIL — used by the owner-seed step.
PRYZM_OWNER_PASSWORD=

# Supabase REST credentials. SERVICE_ROLE_KEY is the server-side key (bypasses
# RLS — keep secret). ANON_KEY is the public/browser key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# Browser-facing duplicates (Vite reads NEXT_PUBLIC_* at build time).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# If you really need the `/api/auth/set-plan` admin escape hatch (you usually
# don't — Stripe webhooks set plans), set a long random secret here. Leaving
# it unset disables the endpoint (fail-closed — recommended).
INTERNAL_PLAN_SECRET=

# ─── OPTIONAL — BILLING (Stripe) ───────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ARCHITECT_MONTHLY=
STRIPE_PRICE_ARCHITECT_ANNUAL=
STRIPE_PRICE_STUDIO_MONTHLY=
STRIPE_PRICE_STUDIO_ANNUAL=
STRIPE_PRICE_FIRM_MONTHLY=
STRIPE_PRICE_FIRM_ANNUAL=

# ─── OPTIONAL — OAUTH ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── OPTIONAL — OBSERVABILITY ──────────────────────────────────────────────
# Set both to enable real OpenTelemetry export. Without an endpoint, P8 spans
# go nowhere and observability is a no-op (§H19 audit fix).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=pryzm-server
OTEL_EXPORTER_OTLP_HEADERS=

# ─── OPTIONAL — MISC ───────────────────────────────────────────────────────
# Pin a specific Anthropic model snapshot (default: claude-haiku-4-5 alias).
ANTHROPIC_MODEL_ID=
# Autodesk APS (DWG conversion) — only needed if /api/import/dwg is used.
APS_CLIENT_ID=
APS_CLIENT_SECRET=
# Family marketplace virus scanner toggle (currently a stub — see §B3 audit).
FAMILY_VIRUS_SCAN=
# Replit-specific (only when deployed on Replit).
REPLIT_DEV_DOMAIN=
PORT=5000
NODE_ENV=development
