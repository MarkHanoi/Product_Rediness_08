# pryzm-selfhost/.env.example
#
# Copy to `.env` and edit before running `docker compose up`.
# `install.sh` does this automatically on first run.
#
# Secrets (Postgres + MinIO passwords) are NOT in this file — they live in
# .secrets/postgres_password and .secrets/minio_password (generated by install.sh
# via `openssl rand -hex 24`).  Compose mounts them as Docker secrets.

# ── Application image versions ──────────────────────────────────────────────
# Override to pin to a specific PRYZM release.  Defaults are baked into
# docker-compose.yml at the canonical release tag.
PRYZM_VERSION=2.0.0

# ── Logging ─────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info

# ── Bake worker concurrency ─────────────────────────────────────────────────
# Number of bake jobs run in parallel per worker container.  Tune to CPU cores.
WORKER_CONCURRENCY=4

# ── Self-host BYO-key safety cap (enforced at S70 per SPEC-28 §11) ──────────
# Maximum monthly AI spend (USD) when self-host operators bring their own
# OpenAI / Anthropic keys.  Defends against runaway loops.  S67 ships the
# env var; the runtime cap lands in S70 (api-gateway AI router).
SELF_HOST_AI_MONTHLY_CAP_USD=500

# ── Multi-region (cuttable per [strategic ADR-018] T2.6, decided in S67 D9) ──
# Default: cut.  See docs/architecture/adr/0049-s67-multi-region-cut-decision.md
# Set to 'eu-west' or 'us-east' to opt into Tier-2 regional Supabase primaries.
# This env var is read by the api-gateway at startup; an empty value means
# single-region (default for M36 GA).
PRYZM_REGION=
