{
  "name": "@pryzm/frame-scheduler",
  "version": "0.1.0",
  "description": "PRYZM 2 — L5 frame scheduler.  Owns dirty-flag set, requestFrame priority queue, and the single rAF/idle pump for the entire app (S03 wires the actual rAF; S02 ships the data-structure skeleton).",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
