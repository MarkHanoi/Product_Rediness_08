{
  "name": "@pryzm/schemas",
  "version": "0.1.0",
  "description": "PRYZM 2 — L1 Zod schemas, typed IDs, and createId factory.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types/Id": "./src/types/Id.ts",
    "./factory/createId": "./src/factory/createId.ts",
    "./annotation": "./src/annotation/index.ts",
    "./annotation/dimension": "./src/annotation/dimension.ts",
    "./view": "./src/view/index.ts",
    "./view/view-template": "./src/view/view-template.ts",
    "./sheet": "./src/sheet/index.ts",
    "./sheet/paper-size": "./src/sheet/paper-size.ts",
    "./sheet/sheet": "./src/sheet/sheet.ts",
    "./sheet/title-block": "./src/sheet/title-block.ts",
    "./sheet/widget-payloads": "./src/sheet/widget-payloads.ts",
    "./schedule": "./src/schedule/index.ts",
    "./schedule/schedule": "./src/schedule/schedule.ts",
    "./schedule/formula": "./src/schedule/formula.ts"
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ulid": "^2.3.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
