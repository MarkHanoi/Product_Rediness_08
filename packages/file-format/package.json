{
  "name": "@pryzm/file-format",
  "version": "0.1.0",
  "description": "PRYZM 2 — .pryzm v1 portable ZIP format.  pack / unpack / migration framework.  Spec: phases/PHASE-1D-Q4-M10-M12-BAKE-PRYZM-ALPHA.md §S20.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.js"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@opentelemetry/api": "^1.9.0",
    "@pryzm/persistence-client": "workspace:*",
    "@pryzm/renderer-three": "workspace:*",
    "@pryzm/core-app-model": "workspace:*",
    "@pryzm/command-registry": "workspace:*",
    "@pryzm/frame-scheduler": "workspace:*",
    "@pryzm/input-host": "workspace:*",
    "@pryzm/plugin-annotations": "workspace:*",
    "@pryzm/geometry-column": "workspace:*",
    "@pryzm/geometry-curtain-wall": "workspace:*",
    "@pryzm/geometry-furniture": "workspace:*",
    "@pryzm/geometry-plumbing": "workspace:*",
    "@pryzm/geometry-roof": "workspace:*",
    "@pryzm/geometry-slab": "workspace:*",
    "@pryzm/geometry-stair": "workspace:*",
    "@pryzm/geometry-wall": "workspace:*",
    "@pryzm/room-topology": "workspace:*",
    "@thatopen/components": "^3.4.2",
    "jspdf": "^2.5.2",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^4.4.168",
    "svg2pdf.js": "^2.2.3",
    "uuid": "^11.1.0",
    "web-ifc": "^0.0.77",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
