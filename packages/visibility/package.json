{
  "name": "@pryzm/visibility",
  "version": "0.1.0",
  "description": "PRYZM 2 — Visibility-Intent legacy adapter (post-2B closeout / ADR-0030). Skeleton port of waves 3–4 of the legacy 11-wave Visibility-Intent system; full port at S49.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./waves": "./src/waves/index.ts"
  },
  "files": ["src"],
  "scripts": {
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:quarantined": "vitest run __tests__/quarantined --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
