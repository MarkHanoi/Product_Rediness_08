{
  "name": "@pryzm/picking",
  "version": "0.1.0",
  "description": "PRYZM 2 — L5 picking layer.  GPU-pick (default) + BVH-pick (fallback) strategies behind a single PickStrategy interface.  Spec: PHASE-1C §S16, ADR-0015.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./snapping": "./src/snapping/index.ts"
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pryzm/snapping": "workspace:*",
    "@pryzm/spatial-index": "workspace:*",
    "@pryzm/scene-committer": "workspace:*",
    "@pryzm/stores": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "three": "^0.183.0",
    "three-mesh-bvh": "^0.9.9"
  },
  "devDependencies": {
    "@types/three": "^0.183.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
