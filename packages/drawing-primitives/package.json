{
  "name": "@pryzm/drawing-primitives",
  "version": "0.1.0",
  "description": "PRYZM 2 — vector primitive set + multi-backend rendering (Canvas2D live, SVG/PDF/Print-Canvas typed stubs). Post-2B closeout / ADR-0029. Closes the architectural lie that the old edge-projection.ts header documented (downstream emitter package now exists).",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./classifier-to-primitives": "./src/classifier-to-primitives.ts",
    "./backends/canvas2d": "./src/backends/canvas2d.ts",
    "./backends/svg": "./src/backends/svg.ts",
    "./backends/pdf": "./src/backends/pdf.ts",
    "./backends/print-canvas": "./src/backends/print-canvas.ts",
    "./dimensions": "./src/dimensions.ts"
  },
  "files": ["src"],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
