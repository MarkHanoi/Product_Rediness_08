{
  "name": "@pryzm/ai-host",
  "version": "0.1.0",
  "description": "PRYZM 2 — AI host (S47). Runs at architectural layer L7.5 per [strategic ADR-014]: above the editor shell (L7), below the user (L8). Public surface is `getAiHost(): Promise<AiHost>` — the impl is loaded via dynamic `import('./AiHost.impl.js')` so Vite tree-shakes `AiHost.impl` out of the editor's main bundle. Zero AI-host bytes in the editor's first-paint chunk per spec lines 587-611. Full L7.5 promotion + CV pipeline + generative workflows land at S49-S52.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./tracing": "./src/tracing.ts",
    "./validators": "./src/workflows/apartmentLayout/validators/index.ts",
    "./validators/validate-and-format": "./src/workflows/apartmentLayout/validators/validate-and-format.ts",
    "./validators/layout-adapter": "./src/workflows/apartmentLayout/validators/layout-adapter.ts",
    "./validators/orchestrator-types": "./src/workflows/apartmentLayout/validators/orchestrator-types.ts",
    "./reporting": "./src/workflows/apartmentLayout/reporting/index.ts"
  },
  "files": ["src"],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
