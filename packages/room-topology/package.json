{
  "name": "@pryzm/room-topology",
  "version": "0.1.0",
  "description": "PRYZM — Room topology layer: spatial index (O(log n) AABB queries) + adjacency graph (StoreEventBus-driven). Migrated from src/engine/subsystems/topology/ (Task 5.1, C01 §3).",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pryzm/core-app-model": "workspace:*",
    "@pryzm/renderer-three": "workspace:*",
    "@pryzm/geometry-wall": "workspace:*",
    "@pryzm/geometry-curtain-wall": "workspace:*",
    "@pryzm/command-registry": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
