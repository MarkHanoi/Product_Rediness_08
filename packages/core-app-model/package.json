{
  "name": "@pryzm/core-app-model",
  "version": "0.1.0",
  "description": "PRYZM \u2014 Core application model layer (Wave 10 LIFT). Drawing pipeline worker-protocol types, pen/hatch/poche style tables migrated from src/core/drawing/. L3 layer: no DOM frameworks; pure Canvas2D globals only.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./drawing": "./src/drawing/index.ts",
    "./presentation": "./src/presentation/index.ts",
    "./presentation/migrations": "./src/presentation/migrations/index.ts",
    "./hierarchy": "./src/hierarchy/index.ts",
    "./catalog": "./src/catalog/index.ts",
    "./context": "./src/context/index.ts",
    "./navigation": "./src/navigation/index.ts",
    "./persistence": "./src/persistence/index.ts",
    "./views": "./src/views/index.ts",
    "./stores": "./src/stores/index.ts",
    "./schedules": "./src/schedules/index.ts",
    "./requirements": "./src/requirements/index.ts",
    "./templates": "./src/templates/index.ts",
    "./types": "./src/types/index.ts",
    "./batch": "./src/batch/index.ts",
    "./material-library": "./src/materialLibrary.ts",
    "./element-registry": "./src/ElementRegistry.ts",
    "./comparison": "./src/comparison/index.ts",
    "./remediation": "./src/remediation/index.ts",
    "./rendering": "./src/rendering/index.ts",
    "./lighting": "./src/lighting/index.ts",
    "./tool-types": "./src/tool-types.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pryzm/event-bus": "workspace:*",
    "three": "^0.183.2",
    "@pryzm/renderer-three": "workspace:*",
    "@pryzm/frame-scheduler": "workspace:*",
    "@thatopen/components": "^3.4.2",
    "@thatopen/components-front": "^3.4.2",
    "zod": "*",
    "immer": "^10.1.1",
    "@pryzm/command-registry": "workspace:*",
    "@pryzm/plugin-annotations": "workspace:*",
    "@pryzm/room-topology": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}