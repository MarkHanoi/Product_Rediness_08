{
  "name": "@pryzm/command-bus",
  "version": "0.1.0",
  "description": "PRYZM 2 — L2 command bus.  Handler registry + Immer-patch producer + MessagePack PatchEmitter (ADR-004) + EventLogPersistor + bounded UndoStack + OTel `pryzm.command.execute` span.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@opentelemetry/api": "^1.9.0",
    "@pryzm/protocol": "workspace:*",
    "@pryzm/runtime-undo-stack": "workspace:*",
    "@pryzm/schemas": "workspace:*",
    "immer": "^10.1.1",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
