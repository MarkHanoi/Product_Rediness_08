{
  "name": "@pryzm/plugin-schedules",
  "version": "0.1.0",
  "description": "PRYZM 2 \u2014 Schedules plugin (S41 / Phase 2C / ADR-0032). Schedule store + 6 handlers (CreateSchedule / DeleteSchedule / AddColumn / RemoveColumn / SetGroupBy / SetFilter), pure-TS formula DSL parser + evaluator, snapshot-based reactive table view.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./errors": "./src/errors.ts",
    "./formula-evaluator": "./src/formula-evaluator.ts",
    "./evaluate-schedule": "./src/evaluate-schedule.ts",
    "./handlers": "./src/handlers/index.ts",
    "./intent": "./src/intent.ts",
    "./sort": "./src/sort.ts",
    "./tracing": "./src/tracing.ts",
    "./view": "./src/view.ts",
    "./export": "./src/export/index.ts",
    "./export/csv": "./src/export/csv.ts",
    "./export/xlsx": "./src/export/xlsx.ts",
    "./export/pdf": "./src/export/pdf.ts",
    "./import/csv": "./src/import/csv.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "pdf-lib": "^1.17.1",
    "@pryzm/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
