{
  "name": "@pryzm/plugin-sheets",
  "version": "0.1.0",
  "description": "PRYZM 2 \u2014 Sheets plugin (S37 / Phase 2C / ADR-0031). Sheet store, 4 handlers (CreateSheet / DeleteSheet / RenameSheet / ReorderSheet), Canvas2D sheet-editor host, and sheet-list view-model.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./errors": "./src/errors.ts",
    "./handlers": "./src/handlers/index.ts",
    "./intent": "./src/intent.ts",
    "./sheet-camera": "./src/sheet-camera.ts",
    "./sheet-editor-host": "./src/sheet-editor-host.ts",
    "./sheet-list": "./src/sheet-list.ts",
    "./title-block": "./src/title-block.ts",
    "./tracing": "./src/tracing.ts",
    "./viewport": "./src/viewport.ts",
    "./widgets": "./src/widgets/index.ts",
    "./widget-tool-palette": "./src/widget-tool-palette.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pryzm/plugin-plan-view": "workspace:*",
    "@pryzm/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
