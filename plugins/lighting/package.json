{
  "name": "@pryzm/plugin-lighting",
  "version": "0.1.0",
  "description": "PRYZM 2 \u2014 Second-tier lighting plugin (S26 / ADR-0023). 5 handlers: CreateLighting / DeleteLighting / MoveLighting / SetLightingIntensity / SetLightingEmergency. Committer is the only place permitted to attach a THREE.PointLight (P2 lint exception lives under src/committer/).",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./store": "./src/store.ts",
    "./errors": "./src/errors.ts",
    "./handlers": "./src/handlers/index.ts",
    "./intent": "./src/intent.ts",
    "./tool": "./src/tool.ts",
    "./committer": "./src/committer/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "three": "^0.183.2",
    "@pryzm/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/three": "^0.183.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
