{
  "name": "@pryzm/plugin-dimensions",
  "version": "0.1.0",
  "description": "PRYZM 2 \u2014 Dimension annotations plugin (S29 / ADR-0028). 6 handlers: CreateDimension / DeleteDimension / MoveDimension / SetDimensionPrecision / SetDimensionUnit / SetDimensionText.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./store": "./src/store.ts",
    "./errors": "./src/errors.ts",
    "./handlers": "./src/handlers/index.ts",
    "./intent": "./src/intent.ts",
    "./tool": "./src/tool.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pryzm/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
