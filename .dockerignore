# .dockerignore — keeps the Docker build context lean and reproducible.
# Anything matched here is NOT sent to the Docker daemon, so it can't accidentally
# end up in the final image even if the Dockerfile says `COPY . .`.
# Pair this with the Dockerfile multi-stage copy — the `runtime` stage is also
# defensive about what it pulls from the builder.

# ─── VCS, IDE, and Replit metadata ──────────────────────────────────────────
# Source-of-truth lives in the registry; .git/ is huge and untrusted at build.
.git
.gitignore
.gitattributes
.github
.idea
.vscode
.replit
replit.nix
replit.md

# ─── Local agent / Claude state ─────────────────────────────────────────────
# .claude/ holds local IDE state, scheduled-tasks lockfiles, settings.local.json
# with developer-specific permissions. Never goes into a production image.
.claude

# ─── Reference repo (NOT a submodule) ───────────────────────────────────────
# MasterMiawW is a sibling chatbot reference (see memory note); it has its own
# .git/ and unrelated dependencies. Excluding saves ~hundreds of MB of context.
MasterMiawW

# ─── node_modules at every depth ────────────────────────────────────────────
# `pnpm install` runs INSIDE the builder stage; shipping a host node_modules
# would pollute the cache with OS-specific binaries (esbuild, sharp, etc.).
node_modules
**/node_modules
.pnpm-store

# ─── Build outputs ──────────────────────────────────────────────────────────
# dist/ is regenerated by `pnpm run build`. Shipping a host-built dist/ would
# bypass the deterministic CI build and risk shipping uncommitted changes.
dist
**/dist
# apex pre-render output (ADR-055 §0 + scripts/build/prerender-apex.mjs).
# Cloudflare Pages serves this; the Fly image must never contain it.
**/dist-apex
build
**/build
**/.next
**/.astro
.vite-cache
.turbo

# ─── Tests (NOT needed at runtime) ──────────────────────────────────────────
# Test fixtures + snapshots are >50MB combined and never executed in prod.
tests
**/__tests__
**/__snapshots__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
playwright.config.ts
playwright-report
.playwright
test-results

# ─── Coverage + CI artefacts ───────────────────────────────────────────────
coverage
.nyc_output

# ─── Docs (heavy + irrelevant to the running server) ───────────────────────
# *.md files in source dirs are stripped except LICENSE (legal requirement).
# Note: we KEEP CLAUDE.md out as well — it's a dev guide, not runtime config.
**/*.md
!LICENSE
!LICENSE.md
# docs-site is a separate Astro app — out of scope for the editor image.
apps/docs-site
# bench app is dev-only perf harness; not needed at runtime.
apps/bench

# ─── Logs + tmp ─────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
.tmp
.local
.local-*
.replit-cache
.upm

# ─── Env + secrets (CRITICAL — never ship these) ────────────────────────────
# Real secrets come from Fly's `flyctl secrets set` at deploy time.
.env
.env.*
!.env.example
pryzm-selfhost/.secrets
pryzm-selfhost/.env

# ─── OS noise ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Heavy assets that aren't needed at build/runtime ───────────────────────
# `attached_assets/` is Claude chat-paste history (see .gitignore §H28).
# `screenshots/` is dev evidence, not served.
attached_assets
generated_assets
screenshots
*.iso
*.tar
*.zip
*.7z

# ─── TypeScript incremental cache ───────────────────────────────────────────
# tsbuildinfo files leak host-absolute paths and confuse later incremental builds.
*.tsbuildinfo

# ─── Docker self-reference ──────────────────────────────────────────────────
# Avoid re-copying the Dockerfile into the image (harmless, just noise).
Dockerfile
.dockerignore
