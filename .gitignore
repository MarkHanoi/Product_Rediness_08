node_modules/
dist/
# Apex pre-render output — generated by `pnpm build:apex` (ADR-055 §0 / C51 §6.1).
# Cloudflare Pages rebuilds this from source; a committed copy would only drift.
dist-apex/
**/dist-apex/
.cache/
*.log
.DS_Store
.env
.env.local
.env.*.local
!.env.example

# §H30 — TypeScript incremental build cache must never be committed
*.tsbuildinfo

# §H28 — Claude chat-paste history / scratchpad — not source
attached_assets/
.agents/attached_assets/

# §L6 — local developer scratch files (TypeScript error dumps, etc.)
.local/
.local-*.txt
.local-*.json

# §A.31.e fix — MasterMiawW is a REFERENCE chatbot repo (see memory note
# mastermiaww-rac-chatbot-reference). Lives as its own git repo at
# ./MasterMiawW/ but is NOT a submodule of this repo (no .gitmodules).
# Excluded so it doesn't re-appear in git's index + break Cloudflare clones.
MasterMiawW/
