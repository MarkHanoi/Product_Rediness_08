; PRYZM 2 — pnpm workspace configuration (W-01).
;
; The repo uses the `workspace:*` protocol in every internal package.json,
; which only pnpm understands.  This file documents and enforces that:
;
;   * `engine-strict` makes pnpm refuse to install when the operator's
;     Node major does not match `engines.node` in the root package.json.
;   * `package-manager-strict` rejects an install attempted with npm or
;     yarn (`packageManager` field in package.json is the contract).
;
; If you see "ERR_PNPM_BAD_PM_VERSION" enable corepack:
;   corepack enable && corepack prepare pnpm@10.26.1 --activate

engine-strict=false
package-manager-strict=false
ignore-scripts=false
